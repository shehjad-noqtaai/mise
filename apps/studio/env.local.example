# Copy to repo root as `.env.local` for local dev URL overrides.
#
# cp apps/studio/env.local.example .env.local
#
# Local Astro + local Studio (default):
# SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
#
# Local Studio → dev web worker on Cloudflare (match GitHub Development var):
# SANITY_STUDIO_PREVIEW_URL=https://mise-web-dev.shehjkhan.workers.dev
# SANITY_STUDIO_URL=https://mise-kitchen-os.sanity.studio

SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
SANITY_STUDIO_URL=http://localhost:3333
