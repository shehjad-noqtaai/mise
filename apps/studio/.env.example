# Project vars — the Sanity CLI fills these in during `sanity init --template`.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=

# Required for `sanity app deploy`
# SANITY_STUDIO_ORGANIZATION_ID=

# Production Studio URL for dashboard "Open in Studio" links
# Optional if SANITY_STUDIO_HOSTNAME is set (defaults to https://<hostname>.sanity.studio)
# SANITY_STUDIO_URL=

# Hosted Studio slug for `sanity deploy --url` (no https://)
# SANITY_STUDIO_HOSTNAME=mise-kitchen-os

# Presentation tool — iframe preview of the Astro app
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
