{
  "name": "studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "typecheck": "tsc --noEmit",
    "schema:extract": "sanity manifest extract --path ./dist/static",
    "schema:deploy": "sanity build && sanity deploy --no-build -y --url mise-kitchen-os",
    "typegen": "SANITY_SCHEMA_EXTRACT=1 sanity schema extract && sanity typegen generate",
    "seed": "sanity migration run seed-locales --no-dry-run --no-confirm",
    "generate-sample-data": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/generate-sample-data.ts --with-user-token -- --out sample-data.ndjson",
    "import-sample-data": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/import-sample-data.ts --with-user-token",
    "verify-translation": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/verify-translation.ts --with-user-token",
    "generate-recipe-images": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/generate-recipe-images.ts --with-user-token",
    "migrate-recipe-images": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-recipe-images-to-media-library.ts --with-user-token",
    "migrate-translation-metadata": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-translation-metadata-v5.ts --with-user-token",
    "migrate-field-i18n-to-plain": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-field-i18n-to-plain.ts --with-user-token",
    "migrate-taxonomy-to-field-i18n": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-taxonomy-to-field-i18n.ts --with-user-token",
    "migrate-recipe-category-kinds": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-recipe-category-kinds.ts --with-user-token",
    "migrate-recipe-categories": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/migrate-recipe-categories.ts --with-user-token",
    "cleanup-orphan-assets": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/delete-orphan-assets.ts --with-user-token",
    "bootstrap": "NODE_OPTIONS='--import tsx/esm' sanity exec scripts/bootstrap.ts --with-user-token"
  },
  "dependencies": {
    "@sanity/agent-context": "^0.6.0",
    "@sanity/assist": "catalog:",
    "@sanity/client": "catalog:",
    "@sanity/icons": "catalog:",
    "@sanity/vision": "catalog:",
    "@starter/l10n": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sanity": "catalog:",
    "styled-components": "catalog:"
  },
  "devDependencies": {
    "@portabletext/markdown": "^1.1.3",
    "@starter/sanity-types": "workspace:*",
    "@starter/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
