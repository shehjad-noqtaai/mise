---
import '../styles/global.css'
import {stegaClean} from '@sanity/client/stega'
import {perspectiveCookieName} from '@sanity/preview-url-secret/constants'
import AppShell from '../components/AppShell.astro'
import LocaleSwitcher from '../components/LocaleSwitcher.astro'
import SanityVisualEditing from '../components/SanityVisualEditing'
import DisableDraftMode from '../components/DisableDraftMode'
import type {Locale} from '../lib/i18n'

interface Props {
  locale: Locale
  title: string
  description?: string
  currentPath?: string
  alternateSlugs?: Record<string, string | undefined>
}

const {
  locale,
  title,
  description = 'Mise — your kitchen operating system',
  currentPath = '/',
  alternateSlugs,
} = Astro.props

const draftMode = Astro.cookies?.has(perspectiveCookieName) ?? false
const pageTitle = draftMode ? stegaClean(title) : title
const pageDescription = draftMode ? stegaClean(description) : description
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#173124" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle} · Mise</title>
  </head>
  <body class="min-h-screen bg-background pb-24 md:pb-0">
    <AppShell locale={locale} currentPath={currentPath}>
      <LocaleSwitcher slot="actions" locale={locale} currentPath={currentPath} alternateSlugs={alternateSlugs} />
    </AppShell>
    <main class="mx-auto max-w-[var(--container-max)] px-[var(--spacing-container-margin)] py-[var(--spacing-section-gap)]">
      <slot />
    </main>
    {
      draftMode && (
        <>
          <SanityVisualEditing client:only="react" />
          <DisableDraftMode client:only="react" />
        </>
      )
    }
  </body>
</html>
