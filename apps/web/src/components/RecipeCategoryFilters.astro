---
import type {Locale} from '../lib/i18n'
import {
  filterGroupLabels,
  clearRecipeFilter,
  recipeDirectoryUrl,
  type RecipeFilters,
} from '../lib/recipe-filters'

interface CategoryOption {
  kind?: string | null
  slug?: string | null
  title?: string | null
}

interface Props {
  locale: Locale
  categories: CategoryOption[] | null | undefined
  active: RecipeFilters
}

const {locale, categories, active} = Astro.props
const labels = filterGroupLabels[locale]

const groups = [
  {key: 'cuisine' as const, label: labels.cuisine},
  {key: 'course' as const, label: labels.course},
]

function optionsFor(kind: 'cuisine' | 'course') {
  return (categories ?? []).filter((cat) => cat.kind === kind && cat.slug && cat.title)
}
---

<div class="mt-8 space-y-6">
  {
    groups.map((group) => {
      const options = optionsFor(group.key)
      if (options.length === 0) return null

      return (
        <div>
          <p class="font-label-md text-on-surface-variant">{group.label}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <a
              href={recipeDirectoryUrl(locale, clearRecipeFilter(active, group.key))}
              class:list={[
                'inline-flex items-center rounded-full border px-4 py-2 font-label-md transition-colors',
                !active[group.key]
                  ? 'border-primary bg-primary text-on-primary'
                  : 'border-outline-variant bg-surface-container-lowest text-on-surface-variant hover:border-primary hover:text-primary',
              ]}
            >
              {labels.all}
            </a>
            {
              options.map((option) => {
                const isActive = active[group.key] === option.slug
                const href = isActive
                  ? recipeDirectoryUrl(locale, clearRecipeFilter(active, group.key))
                  : recipeDirectoryUrl(locale, {...active, [group.key]: option.slug!})

                return (
                  <a
                    href={href}
                    class:list={[
                      'inline-flex items-center rounded-full border px-4 py-2 font-label-md transition-colors',
                      isActive
                        ? 'border-primary bg-primary text-on-primary'
                        : 'border-outline-variant bg-surface-container-lowest text-on-surface-variant hover:border-primary hover:text-primary',
                    ]}
                  >
                    {option.title}
                  </a>
                )
              })
            }
          </div>
        </div>
      )
    })
  }
</div>
