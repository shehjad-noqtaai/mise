---
interface Props {
  href: string
  class?: string
}

const {href, class: className = ''} = Astro.props
---

<a
  href={href}
  class:list={['group inline-flex items-center gap-2.5 transition-opacity hover:opacity-90', className]}
  aria-label="Mise home"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="none"
    class="size-8 shrink-0"
    aria-hidden="true"
  >
    <rect width="32" height="32" rx="8" class="fill-primary"></rect>
    <path
      d="M8.5 22.5V9.5l5.25 8.25L19 9.5v13"
      stroke="#FAF9F6"
      stroke-width="2.25"
      stroke-linecap="round"
      stroke-linejoin="round"></path>
    <circle cx="23.25" cy="10.25" r="2.15" class="fill-sage-green"></circle>
    <path
      d="M21.5 23.5h3.5"
      stroke="#B0CDBB"
      stroke-width="1.75"
      stroke-linecap="round"></path>
  </svg>
  <span class="font-headline-md text-primary">Mise</span>
</a>
