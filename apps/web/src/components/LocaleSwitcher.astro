---
import {getRelativeLocaleUrl} from 'astro:i18n'
import {LOCALES, type Locale} from '../lib/i18n'

interface Props {
  locale: Locale
  currentPath: string
  alternateSlugs?: Record<string, string | undefined>
}

const {locale, currentPath, alternateSlugs = {}} = Astro.props

function targetPath(targetLocale: Locale) {
  if (currentPath.startsWith('recipes/') && alternateSlugs[targetLocale]) {
    return `recipes/${alternateSlugs[targetLocale]}/`
  }
  return currentPath
}
---

<div class="inline-flex items-center gap-0.5 rounded-full border border-outline-variant bg-surface-container-low p-1">
  {
    LOCALES.map((code) => (
      <a
        href={getRelativeLocaleUrl(code, targetPath(code))}
        class:list={[
          'inline-flex min-w-9 items-center justify-center rounded-full px-3 py-1.5 font-label-sm transition-colors',
          code === locale
            ? 'bg-primary text-on-primary shadow-sm'
            : 'text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface',
        ]}
      >
        {code === 'en-US' ? 'EN' : 'HI'}
      </a>
    ))
  }
</div>
