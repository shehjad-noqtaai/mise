---
interface Props {
  href: string
  variant?: 'primary' | 'secondary' | 'ghost'
  class?: string
}

const {href, variant = 'primary', class: className = ''} = Astro.props

const variants = {
  primary: 'bg-primary text-on-primary shadow-sm hover:brightness-110 active:brightness-95',
  secondary:
    'border border-outline bg-surface-container-lowest text-primary hover:bg-secondary-container hover:text-on-secondary-container',
  ghost: 'text-on-surface-variant hover:bg-surface-container-low hover:text-on-surface',
}
---

<a
  href={href}
  class:list={[
    'touch-target inline-flex items-center justify-center rounded-2xl px-6 font-label-md transition-colors',
    variants[variant],
    className,
  ]}
>
  <slot />
</a>
