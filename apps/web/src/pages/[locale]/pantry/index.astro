---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import InventoryProgressBar from '../../../components/InventoryProgressBar.astro'
import {loadQuery} from '../../../lib/sanity/load-query'
import {getDraftModeProps} from '../../../lib/sanity/draft-mode'
import {PANTRY_SNAPSHOT_QUERY} from '../../../lib/sanity/queries'
import type {PANTRY_SNAPSHOT_QUERY_RESULT} from '@starter/sanity-types'
import {DEFAULT_LOCALE, localizedValue, localeFromParam} from '../../../lib/i18n'
import {getRelativeLocaleUrl} from 'astro:i18n'

export const prerender = false

const locale = localeFromParam(Astro.params.locale)
if (!locale) {
  return Astro.redirect(getRelativeLocaleUrl(DEFAULT_LOCALE, 'pantry/'))
}

const {data: pantry} = await loadQuery<PANTRY_SNAPSHOT_QUERY_RESULT>({
  query: PANTRY_SNAPSHOT_QUERY,
  params: {locale},
  ...getDraftModeProps(Astro.cookies),
})
---

<BaseLayout
  locale={locale}
  title={pantry?.title ?? 'Pantry'}
  currentPath="pantry/"
>
  <div class="max-w-3xl">
    <h1 class="font-display-lg text-primary">{pantry?.title ?? (locale === 'hi-IN' ? 'पेंट्री' : 'Pantry Management')}</h1>
    <p class="mt-4 font-body-lg text-on-surface-variant">{pantry?.description}</p>
  </div>

  <div class="mt-10 grid gap-4 md:grid-cols-2">
    {
      pantry?.items?.map((item) => (
        <InventoryProgressBar
          quantity={item.quantity}
          capacity={item.capacity}
          label={`${localizedValue(item.ingredientName, locale) ?? 'Item'}${item.location ? ` · ${localizedValue(item.location, locale)}` : ''}`}
        />
      ))
    }
  </div>
</BaseLayout>
