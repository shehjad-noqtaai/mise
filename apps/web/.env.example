# Web app env — in this monorepo, copy the repo root `.env.example` to `.env`.
# Astro loads env from the repo root (`vite.envDir: ../../` in astro.config.mjs).
#
# These vars are listed here for template validation and local reference.

# Sanity (required for build and SSR)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Draft mode / Presentation tool (optional locally; required on Cloudflare Worker for preview)
SANITY_API_READ_TOKEN=

# Stega overlays link back to Studio
SANITY_STUDIO_URL=http://localhost:3333

# Cloudflare Workers deploy (optional — set in CI secrets or shell)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
