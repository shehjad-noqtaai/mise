{
  "name": "mise",
  "version": "0.1.0",
  "private": true,
  "description": "Mise kitchen operating system — Sanity CMS, Astro frontend, AI-powered localization.",
  "keywords": [
    "agent-actions",
    "agentic",
    "ai",
    "app-sdk",
    "automation",
    "dashboard",
    "glossary",
    "groq",
    "i18n",
    "l10n",
    "localization",
    "prompt-assembly",
    "sanity",
    "studio",
    "style-guide",
    "translation"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "SANITY_STUDIO_SERVER_OPEN=true concurrently -n studio,dashboard,functions,web -c \"#f03e2f,#43b1b0,#f5a623,#8b5cf6\" \"pnpm --filter studio dev\" \"pnpm --filter @starter/translations-dashboard dev\" \"pnpm --filter @starter/functions dev\" \"pnpm --filter web dev\"",
    "build": "pnpm -r build",
    "deploy": "pnpm -r deploy",
    "bootstrap": "pnpm --filter studio bootstrap",
    "test": "pnpm -r test",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typegen": "pnpm --filter studio typegen",
    "pretypecheck": "pnpm run typegen",
    "typecheck": "pnpm -r typecheck",
    "validate": "sanity-template-validate"
  },
  "devDependencies": {
    "@sanity/blueprints": "0.12.2",
    "@sanity/client": "catalog:",
    "@sanity/template-validator": "^3.0.0",
    "@starter/eslint-config": "workspace:*",
    "@types/node": "^22.19.13",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.3",
    "groq": "catalog:",
    "oxfmt": "^0.36.0",
    "sanity": "catalog:",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.30.3"
}
