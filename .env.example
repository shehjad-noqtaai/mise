# Sanity (create at https://www.sanity.io/organizations/ofsMxPwd5)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# SANITY_STUDIO_ORGANIZATION_ID=ofsMxPwd5

# Astro build/runtime (mirrors studio vars)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Required for visual editing / draft mode in the Astro app (also set as a Wrangler secret in production)
SANITY_API_READ_TOKEN=

# ── URL wiring (Studio ↔ Web) ───────────────────────────────────────────────
# Use apps/studio/env.local.example → copy to repo root `.env.local` for local-only overrides.
#
# SANITY_STUDIO_HOSTNAME — slug for `sanity deploy --url` (no https://)
#   Production: mise-kitchen-os
#   Dev:        mise-kitchen-os-dev  (example)
#
# SANITY_STUDIO_PREVIEW_URL — where the Presentation tool loads the Astro app
#   Local:      http://localhost:4321
#   Dev:        https://mise-web-dev.shehjkhan.workers.dev
#   Production: https://mise-web.shehjkhan.workers.dev
#
# SANITY_STUDIO_URL — where stega / visual-editing links point back to Studio
#   Optional if SANITY_STUDIO_HOSTNAME is set (defaults to https://<hostname>.sanity.studio)
#   Local:      http://localhost:3333
#   Production: https://mise-kitchen-os.sanity.studio
# SANITY_STUDIO_HOSTNAME=
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
SANITY_STUDIO_URL=http://localhost:3333

# Cloudflare deploy (CI)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
