# Sanity (create at https://www.sanity.io/organizations/ofsMxPwd5)
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# SANITY_STUDIO_ORGANIZATION_ID=ofsMxPwd5

# Astro build/runtime (mirrors studio vars)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Required for visual editing / draft mode in the Astro app
SANITY_API_READ_TOKEN=

# Local preview URL for Studio Presentation tool
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321

# Local Studio URL embedded in stega overlays (also set in astro.config via stega.studioUrl)
SANITY_STUDIO_URL=http://localhost:3333

# Production Studio URL for dashboard "Open in Studio" links
# SANITY_STUDIO_URL=https://mise-kitchen-os.sanity.studio

# Cloudflare deploy (CI)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
